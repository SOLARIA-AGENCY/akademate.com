{
  "name": "@akademate/realtime",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time Socket.io infrastructure for Akademate dashboards",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    },
    "./context": {
      "types": "./src/context/index.ts",
      "default": "./src/context/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "ioredis": "^5.10.1",
    "jose": "^5.10.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "jsdom": "^27.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
