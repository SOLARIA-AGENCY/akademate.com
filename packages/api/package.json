{
  "name": "@akademate/api",
  "version": "1.0.0",
  "description": "API utilities - middleware, handlers, validation for Akademate REST/GraphQL",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./middleware": "./src/middleware/index.ts",
    "./handlers": "./src/handlers.ts",
    "./errors": "./src/errors.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@akademate/db": "workspace:*",
    "@akademate/types": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
