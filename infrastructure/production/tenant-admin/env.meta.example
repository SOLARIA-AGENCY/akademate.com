# Meta Ads / Facebook Integrations (Tenant Admin)
# Use this file as reference and copy values to the real runtime env/tenant config.

# Account identifiers (CEP / SOLARIA)
META_AD_ACCOUNT_ID=730494526974837
META_BUSINESS_ID=598666359737310
META_PIXEL_ID=1189071876088388

# Tokens
# CAPI: event tracking only (Pixel + Conversions API)
META_CONVERSIONS_API_TOKEN=
# Marketing API: required for campaign read/create/publish
# Must include ads_read and/or ads_management in Meta app permissions.
META_MARKETING_API_TOKEN=
# Graph API version for Marketing API and CAPI calls (recommended latest stable).
META_GRAPH_API_VERSION=v25.0

# Safety guard: only operate campaigns matching SOLARIA scope.
META_ALLOWED_CAMPAIGN_PREFIX=SOLARIA AGENCY
